# Veriff API Credentials (required — get from Veriff Station → Integration)
VERIFF_API_KEY=your-api-key-here
VERIFF_API_SECRET=your-shared-secret-key-here
VERIFF_BASE_URL=https://stationapi.veriff.com

# Your ngrok public URL (required — run: ngrok http 3000)
# Example: https://abc123.ngrok-free.app
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Server
PORT=3000
